{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "es2020",
        "module": "preserve",
        "outDir": "ckanext/files/assets/scripts/",
        "types": ["jquery"],
        "strict": true,
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "moduleDetection": "force",

        "inlineSources": true,
        "inlineSourceMap": true,
    },
    "include": ["ckanext/files/assets/ts/*.ts"],
    "exclude": ["ckanext/files/assets/ts/types.d.ts"]
}
